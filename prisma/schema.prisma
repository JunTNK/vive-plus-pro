// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Adulto Mayor - Persona beneficiaria del servicio
model AdultoMayor {
  id                  String    @id @default(cuid())
  
  // Datos personales
  nombre              String
  apellido            String
  fechaNacimiento     DateTime
  genero              String?   // "masculino", "femenino"
  direccion           String
  telefono            String?
  email               String?
  
  // Contacto de emergencia
  contactoEmergencia  String?
  parentescoEmergencia String?  // "hijo/a", "esposo/a", "hermano/a", "otro"
  telefonoEmergencia  String?
  
  // Información médica
  tipoSangre          String?   // "O+", "O-", "A+", "A-", "B+", "B-", "AB+", "AB-"
  peso                Float?    // kg
  talla               Float?    // cm
  imc                 Float?    // calculado
  condicionesSalud    String?   // Condiciones médicas importantes
  medicamentos        String?   // Medicamentos que toma
  alergias            String?   // Alergias conocidas
  cirugias            String?   // Cirugías previas
  usoAyudas           String?   // "ninguna", "baston", "andador", "silla de ruedas", "otro"
  
  // Información de salud mental y cognitiva
  estadoCognitivo     String?   // "normal", "deterioro_leve", "deterioro_moderado", "deterioro_severo"
  estadoEmocional     String?   // "estable", "ansioso", "deprimido", "aislado"
  
  // Nivel de funcionalidad
  nivelIndependencia  String?   // "independiente", "semidependiente", "dependiente"
  requiereAsistencia  String?   // "ninguna", "parcial", "total"
  
  // Información social
  viveSolo            Boolean?
  cuidadorPrincipal   String?
  telefonoCuidador    String?
  
  // Información de seguros
  seguroMedico        String?
  numeroSeguro        String?
  medicoPrimario      String?
  telefonoMedico      String?
  
  // Evaluaciones ECOSAFE
  fechaUltimaEvaluacion DateTime?
  puntajeRiesgo       Int?      // 1-3 Muy Alto, 4-6 Alto, 7-9 Moderado, 10-12 Bajo
  
  // Programa asignado
  programaId          String?
  
  // Estado
  activo              Boolean   @default(true)
  observaciones       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Relaciones
  visitas             Visita[]
  actividades         Actividad[]
  notas               Nota[]
  evaluaciones        Evaluacion[]
  programa            Programa? @relation(fields: [programaId], references: [id])
  
  @@map("adultos_mayores")
}

// Programas preconfigurados
model Programa {
  id                  String    @id @default(cuid())
  nombre              String
  descripcion         String
  objetivo            String
  duracionSemanas     Int       @default(8)
  sesionesPorSemana   Int       @default(3)
  intensidad          String    // "baja", "moderada", "alta"
  categoria           String    // "fortalecimiento", "equilibrio", "cognitivo", "movilidad", "recreativo"
  actividades         String    // JSON con lista de actividades sugeridas
  condicionesAdecuadas String?  // Condiciones de salud para las que es adecuado
  contraindicaciones  String?   // Condiciones que contraindican el programa
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  participantes       AdultoMayor[]
  plantillasActividad PlantillaActividad[]
  
  @@map("programas")
}

// Plantillas de actividades preconfiguradas
model PlantillaActividad {
  id                  String    @id @default(cuid())
  programaId          String?
  nombre              String
  descripcion         String
  duracionMinutos     Int       @default(30)
  categoria           String    // "ejercicio", "manualidad", "cognitivo", "recreativo", "movilidad"
  dificultad          String    // "facil", "moderado", "avanzado"
  materiales          String?   // JSON con lista de materiales necesarios
  instrucciones       String?   // Pasos detallados
  beneficios          String?   // Beneficios de la actividad
  precauciones        String?   // Precauciones a considerar
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  programa            Programa? @relation(fields: [programaId], references: [id], onDelete: SetNull)
  
  @@map("plantillas_actividades")
}

// Evaluaciones funcionales ECOSAFE
model Evaluacion {
  id                  String    @id @default(cuid())
  adultoMayorId       String
  fecha               DateTime  @default(now())
  
  // Pruebas ECOSAFE PIVE 2020
  equilibrioEstatico  Int?      // segundos
  levantarseSentarse  Int?      // repeticiones en 30 seg
  flexionTronco       Float?    // cm
  flexionesBrazo      Int?      // repeticiones en 30 seg
  juntarManosEspalda  String?   // "si", "no", "parcial"
  levantarseCaminar   Float?    // segundos
  marcha2Minutos      Int?      // pasos en 2 minutos
  
  // Signos vitales
  presionSistolica    Int?
  presionDiastolica   Int?
  frecuenciaCardiaca  Int?
  frecuenciaRespiratoria Int?
  saturacionOxigeno   Float?
  
  // Puntaje y clasificación
  puntajeTotal        Int?
  clasificacionRiesgo String?   // "muy_alto", "alto", "moderado", "bajo"
  
  // Recomendaciones
  observaciones       String?
  recomendaciones     String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  adultoMayor         AdultoMayor @relation(fields: [adultoMayorId], references: [id], onDelete: Cascade)
  
  @@map("evaluaciones")
}

// Visitas domiciliarias
model Visita {
  id              String    @id @default(cuid())
  adultoMayorId   String
  fecha           DateTime
  duracion        Int       // Duración en minutos
  tipoVisita      String    // "rutinaria", "seguimiento", "urgente", "recreativa"
  estado          String    // "programada", "completada", "cancelada"
  observaciones   String?
  
  // Sincronización con Google Calendar
  googleEventId   String?   @unique
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  adultoMayor     AdultoMayor @relation(fields: [adultoMayorId], references: [id], onDelete: Cascade)
  
  @@map("visitas")
}

// Actividades recreativas realizadas
model Actividad {
  id                  String    @id @default(cuid())
  adultoMayorId       String
  plantillaActividadId String?
  fecha               DateTime
  tipoActividad       String    // "ejercicio", "manualidad", "lectura", "musica", "juego", "cognitivo", "movilidad", "otra"
  titulo              String
  descripcion         String?
  duracion            Int?      // Duración en minutos
  intensidad          String?   // "baja", "moderada", "alta"
  notas               String?   // Observaciones sobre la actividad
  dificultad          String?   // Percepción de dificultad
  satisfaccion        Int?      // 1-5 escala de satisfacción
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  adultoMayor         AdultoMayor @relation(fields: [adultoMayorId], references: [id], onDelete: Cascade)
  
  @@map("actividades")
}

// Notas de seguimiento
model Nota {
  id              String    @id @default(cuid())
  adultoMayorId   String
  fecha           DateTime  @default(now())
  titulo          String
  contenido       String
  tipo            String    // "general", "salud", "emocional", "familiar"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  adultoMayor     AdultoMayor @relation(fields: [adultoMayorId], references: [id], onDelete: Cascade)
  
  @@map("notas")
}

// Configuración del sistema
model Configuracion {
  id              String    @id @default(cuid())
  clave           String    @unique  // Nombre de la variable
  valor           String    // Valor de la variable
  descripcion     String?   // Descripción de para qué sirve
  categoria       String    @default("general") // "google", "auth", "database", "general"
  esSecreto       Boolean   @default(false) // Si es sensible (no mostrar valor real)
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("configuracion")
}
